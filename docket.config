# Use official PHP image with Apache
FROM php:8.3-apache

# Set environment variables
ENV DRUPAL_VERSION=11.2.2
ENV DOCUMENT_ROOT=/var/www/html
ENV DRUPAL_TEMP_DIR=/tmp/drupal-install

# Default environment (can be overridden at runtime)
ENV ENVIRONMENT=predev

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libzip-dev \
    zip \
    unzip \
    wget \
    default-mysql-client \
    libfreetype6-dev \
    libjpeg62-turbo-dev \
    libwebp-dev \
    libxpm-dev \
    libicu-dev \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions required by Drupal 11
RUN docker-php-ext-configure gd --with-freetype --with-jpeg --with-webp --with-xpm \
    && docker-php-ext-install \
    pdo_mysql \
    mysqli \
    mbstring \
    exif \
    pcntl \
    bcmath \
    gd \
    zip \
    opcache \
    intl \
    soap

# Enable Apache modules
RUN a2enmod rewrite headers

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Create temporary directory for Drupal installation
RUN mkdir -p $DRUPAL_TEMP_DIR

# Set working directory to temporary location
WORKDIR $DRUPAL_TEMP_DIR

# Download and install Drupal 11.2.2 using Composer in temp directory
RUN composer create-project drupal/recommended-project:11.2.2 . --         -interaction

docker build -t exchange git@github.com:CMS-Enterprise/eps-eportal2-drupal-wcm.git


# Install Drush globally using Composer (updated for Drupal 11 compatibility)
RUN composer global require drush/drush:^13.0

# Also install Drush locally in the project for better compatibility
RUN composer require drush/drush:^13.0 --with-all-dependencies

# Update PATH to prioritize local vendor/bin
ENV PATH="/var/www/html/vendor/bin:${PATH}:/root/.composer/vendor/bin:$DRUPAL_TEMP_DIR/vendor/bin"

# Create necessary directories and set proper permissions in temp directory
RUN mkdir -p $DRUPAL_TEMP_DIR/web/sites/default/files \
    && chown -R www-data:www-data $DRUPAL_TEMP_DIR \
    && chmod -R 755 $DRUPAL_TEMP_DIR \
    && chmod -R 775 $DRUPAL_TEMP_DIR/web/sites/default/files

# Configure Apache document root
RUN a2enmod rewrite headers

# Create Apache virtual host configuration for multi-site
RUN echo '<VirtualHost *:80>\n\
 DocumentRoot /var/www/html/web\n\
 ServerName localhost\n\
 ServerAlias *\n\
 <Directory /var/www/html/web>\n\
 Options Indexes FollowSymLinks\n\
 AllowOverride All\n\
 Require all granted\n\
 </Directory>\n\
 ErrorLog ${APACHE_LOG_DIR}/error.log\n\
 CustomLog ${APACHE_LOG_DIR}/access.log combined\n\
</VirtualHost>' > /etc/apache2/sites-available/000-default.conf

# Configure PHP settings for Drupal 11 with PHP 8.3
RUN echo 'memory_limit = 512M\n\
upload_max_filesize = 64M\n\
post_max_size = 64M\n\
max_execution_time = 300\n\
max_input_vars = 3000\n\
opcache.enable = 1\n\
opcache.memory_consumption = 256\n\
opcache.max_accelerated_files = 10000\n\
opcache.revalidate_freq = 2\n\
opcache.validate_timestamps = 1\n\
opcache.interned_strings_buffer = 16\n\
opcache.jit_buffer_size = 100M\n\
opcache.jit = 1255\n\
realpath_cache_size = 4096K\n\
realpath_cache_ttl = 600' > /usr/local/etc/php/conf.d/drupal.ini

# Create environment directory and copy environment files
RUN mkdir -p /opt/drupal/environment
COPY environment/ /opt/drupal/environment/

# Copy the multi-site install script
COPY start-drupal-rds-multisite.sh /usr/local/bin/start-drupal-rds-multisite.sh

# Set permissions for the script
RUN chmod +x /usr/local/bin/start-drupal-rds-multisite.sh

# Create document root directory (this will be mounted by EFS)
RUN mkdir -p $DOCUMENT_ROOT

# Expose port 80
EXPOSE 80

# Start Drupal with multi-site installation
CMD ["/usr/local/bin/start-drupal-rds-multisite.sh"]
